{% set email_enabled = alerting.email.enabled | default(false) | bool %}
{% set telegram_enabled = alerting.telegram.enabled | default(false) | bool %}
{% set slack_enabled = alerting.slack.enabled | default(false) | bool %}
{% set webex_enabled = alerting.webex.enabled | default(false) | bool %}
{% set pagerduty_enabled = alerting.pagerduty.enabled | default(false) | bool %}
{% set routed_receivers_enabled = email_enabled or telegram_enabled or slack_enabled or webex_enabled or pagerduty_enabled %}
global:
  resolve_timeout: {{ alerting.resolve_timeout | default('5m') }}
{% if email_enabled %}
  smtp_smarthost: {{ alerting.email.smarthost | quote }}
  smtp_from: {{ alerting.email.from | quote }}
  smtp_require_tls: {{ alerting.email.require_tls | default(true) | bool | lower }}
{% if alerting.email.auth_enabled | default(true) | bool %}
  smtp_auth_username: {{ vars.vault_alertmanager_smtp_username | quote }}
  smtp_auth_password: {{ vars.vault_alertmanager_smtp_password | quote }}
{% endif %}
{% endif %}

route:
  receiver: "null"
  group_by:
    - alertname
    - category
    - component
    - severity
    - namespace
    - node
    - pod
    - service
    - job
    - persistentvolumeclaim
    - deployment
    - statefulset
  group_wait: {{ alerting.route.group_wait | default('30s') }}
  group_interval: {{ alerting.route.group_interval | default('5m') }}
  repeat_interval: {{ alerting.route.repeat_interval | default('4h') }}
{% if routed_receivers_enabled %}
  routes:
{% if email_enabled %}
    - receiver: "email"
      matchers:
{% for matcher in alerting.email.matchers | default(['severity=~"warning|critical"']) %}
        - {{ matcher | quote }}
{% endfor %}
      continue: true
{% endif %}
{% if telegram_enabled %}
    - receiver: "telegram"
      matchers:
{% for matcher in alerting.telegram.matchers | default(['severity=~"warning|critical"']) %}
        - {{ matcher | quote }}
{% endfor %}
      continue: true
{% endif %}
{% if slack_enabled %}
    - receiver: "slack"
      matchers:
{% for matcher in alerting.slack.matchers | default(['severity=~"warning|critical"']) %}
        - {{ matcher | quote }}
{% endfor %}
      continue: true
{% endif %}
{% if webex_enabled %}
    - receiver: "webex"
      matchers:
{% for matcher in alerting.webex.matchers | default(['severity=~"warning|critical"']) %}
        - {{ matcher | quote }}
{% endfor %}
      continue: true
{% endif %}
{% if pagerduty_enabled %}
    - receiver: "pagerduty"
      matchers:
{% for matcher in alerting.pagerduty.matchers | default(['severity="critical"']) %}
        - {{ matcher | quote }}
{% endfor %}
      continue: true
{% endif %}
{% endif %}

receivers:
  - name: "null"
{% if email_enabled %}
  - name: "email"
    email_configs:
      - to: {{ alerting.email.to | quote }}
        from: {{ alerting.email.from | quote }}
        send_resolved: {{ alerting.email.send_resolved | default(true) | bool | lower }}
        headers:
          subject: >-
{% raw %}
            {{ if eq .Status "firing" }}{{ if eq .CommonLabels.severity "critical" }}🔴{{ else if eq .CommonLabels.severity "warning" }}🟠{{ else }}🔵{{ end }} FIRING{{ else }}✅ RESOLVED{{ end }} | {{ if .CommonLabels.component }}{{ .CommonLabels.component }}{{ else }}kube-prometheus-stack{{ end }} | {{ .CommonLabels.alertname }}
{% endraw %}
        html: |-
{% raw %}
          {{ if eq .Status "firing" }}
            {{ if eq .CommonLabels.severity "critical" }}🔴 <b>FIRING CRITICAL</b>{{ else if eq .CommonLabels.severity "warning" }}🟠 <b>FIRING WARNING</b>{{ else }}🔵 <b>FIRING</b>{{ end }}
          {{ else }}
            ✅ <b>RESOLVED</b>
          {{ end }}
          <br/>
          {{ if match ".*(Primary|SplitBrain|Secondary|Replica|Replication).*" .CommonLabels.alertname }}🔁{{ else if match ".*(CrashLoop|Restart).*" .CommonLabels.alertname }}♻️{{ else if match ".*(Filesystem|Volume|PVC|Disk|Filling|Full).*" .CommonLabels.alertname }}💾{{ else if match ".*(Traefik|Ingress|5xx).*" .CommonLabels.alertname }}🌐{{ else if match ".*(Fluent|Log).*" .CommonLabels.alertname }}📜{{ else if match ".*OpenSearch.*" .CommonLabels.alertname }}🔎{{ else if match ".*(Mongo|Postgres|Database).*" .CommonLabels.alertname }}🗄️{{ else if match ".*(Node|Pod|Deployment|StatefulSet|Kubernetes).*" .CommonLabels.alertname }}☸️{{ else if match ".*(Target|Prometheus|Metrics|Collector).*" .CommonLabels.alertname }}🎯{{ else }}📣{{ end }}
          <b>{{ .CommonLabels.alertname }}</b><br/>
          ----------------------------------------<br/>
          <b>Severity:</b> <code>{{ if .CommonLabels.severity }}{{ .CommonLabels.severity }}{{ else }}unknown{{ end }}</code><br/>
          <b>Category:</b> <code>{{ if .CommonLabels.category }}{{ .CommonLabels.category }}{{ else }}platform{{ end }}</code><br/>
          <b>Component:</b> <code>{{ if .CommonLabels.component }}{{ .CommonLabels.component }}{{ else }}kube-prometheus-stack{{ end }}</code><br/>
          <b>Affected targets:</b> <code>{{ len .Alerts }}</code><br/>
          <b>Status:</b> <code>{{ if eq .Status "resolved" }}recovered{{ else }}active{{ end }}</code><br/>
          ----------------------------------------<br/>
          {{ with index .Alerts 0 }}
          <b>Summary:</b> {{ if .Annotations.summary }}{{ .Annotations.summary }}{{ else }}No summary provided{{ end }}<br/>
          <b>Description:</b> {{ if .Annotations.description }}{{ .Annotations.description }}{{ else }}No description provided{{ end }}<br/>
          {{ end }}
          ----------------------------------------<br/>
          <b>Targets:</b><br/>
          {{ range .Alerts }}
          • {{ if .Labels.node }}node=<code>{{ .Labels.node }}</code> {{ end }}{{ if .Labels.namespace }}ns=<code>{{ .Labels.namespace }}</code> {{ end }}{{ if .Labels.pod }}pod=<code>{{ .Labels.pod }}</code> {{ end }}{{ if .Labels.container }}container=<code>{{ .Labels.container }}</code> {{ end }}{{ if .Labels.persistentvolumeclaim }}pvc=<code>{{ .Labels.persistentvolumeclaim }}</code> {{ end }}{{ if .Labels.service }}svc=<code>{{ .Labels.service }}</code> {{ end }}{{ if .Labels.job }}job=<code>{{ .Labels.job }}</code> {{ end }}{{ if .Labels.endpoint }}endpoint=<code>{{ .Labels.endpoint }}</code> {{ end }}{{ if .Labels.instance }}instance=<code>{{ .Labels.instance }}</code> {{ end }}{{ if .GeneratorURL }}<a href="{{ .GeneratorURL }}">query</a>{{ end }}<br/>
          {{ end }}
{% endraw %}
{% endif %}
{% if telegram_enabled %}
  - name: "telegram"
    telegram_configs:
      - bot_token: {{ vars.vault_alertmanager_telegram_bot_token | quote }}
        chat_id: {{ vars.vault_alertmanager_telegram_chat_id | int }}
        parse_mode: "HTML"
        send_resolved: {{ alerting.telegram.send_resolved | default(true) | bool | lower }}
        message: |-
{% raw %}
          {{ if eq .Status "firing" }}{{ if eq .CommonLabels.severity "critical" }}🔴 <b>FIRING CRITICAL</b>{{ else if eq .CommonLabels.severity "warning" }}🟠 <b>FIRING WARNING</b>{{ else }}🔵 <b>FIRING</b>{{ end }}{{ else }}✅ <b>RESOLVED</b>{{ end }}
          {{ if match ".*(Primary|SplitBrain|Secondary|Replica|Replication).*" .CommonLabels.alertname }}🔁{{ else if match ".*(CrashLoop|Restart).*" .CommonLabels.alertname }}♻️{{ else if match ".*(Filesystem|Volume|PVC|Disk|Filling|Full).*" .CommonLabels.alertname }}💾{{ else if match ".*(Traefik|Ingress|5xx).*" .CommonLabels.alertname }}🌐{{ else if match ".*(Fluent|Log).*" .CommonLabels.alertname }}📜{{ else if match ".*OpenSearch.*" .CommonLabels.alertname }}🔎{{ else if match ".*(Mongo|Postgres|Database).*" .CommonLabels.alertname }}🗄️{{ else if match ".*(Node|Pod|Deployment|StatefulSet|Kubernetes).*" .CommonLabels.alertname }}☸️{{ else if match ".*(Target|Prometheus|Metrics|Collector).*" .CommonLabels.alertname }}🎯{{ else }}📣{{ end }} <b>{{ .CommonLabels.alertname }}</b>
          ----------------------------------------
          <b>Severity:</b> <code>{{ if .CommonLabels.severity }}{{ .CommonLabels.severity }}{{ else }}unknown{{ end }}</code>
          <b>Category:</b> <code>{{ if .CommonLabels.category }}{{ .CommonLabels.category }}{{ else }}platform{{ end }}</code>
          <b>Component:</b> <code>{{ if .CommonLabels.component }}{{ .CommonLabels.component }}{{ else }}kube-prometheus-stack{{ end }}</code>
          <b>Affected targets:</b> <code>{{ len .Alerts }}</code>
          <b>Status:</b> <code>{{ if eq .Status "resolved" }}recovered{{ else }}active{{ end }}</code>
          ----------------------------------------
          {{ with index .Alerts 0 }}
          <b>Summary:</b> {{ if .Annotations.summary }}{{ .Annotations.summary }}{{ else }}No summary provided{{ end }}
          <b>Description:</b> {{ if .Annotations.description }}{{ .Annotations.description }}{{ else }}No description provided{{ end }}
          {{ end }}
          ----------------------------------------
          <b>Targets:</b>
          {{ range .Alerts }}
          • {{ if .Labels.node }}node=<code>{{ .Labels.node }}</code> {{ end }}{{ if .Labels.namespace }}ns=<code>{{ .Labels.namespace }}</code> {{ end }}{{ if .Labels.pod }}pod=<code>{{ .Labels.pod }}</code> {{ end }}{{ if .Labels.container }}container=<code>{{ .Labels.container }}</code> {{ end }}{{ if .Labels.persistentvolumeclaim }}pvc=<code>{{ .Labels.persistentvolumeclaim }}</code> {{ end }}{{ if .Labels.service }}svc=<code>{{ .Labels.service }}</code> {{ end }}{{ if .Labels.job }}job=<code>{{ .Labels.job }}</code> {{ end }}{{ if .Labels.endpoint }}endpoint=<code>{{ .Labels.endpoint }}</code> {{ end }}{{ if .Labels.instance }}instance=<code>{{ .Labels.instance }}</code> {{ end }}{{ if .GeneratorURL }}<a href="{{ .GeneratorURL }}">query</a>{{ end }}
          {{ end }}
{% endraw %}
{% endif %}
{% if slack_enabled %}
  - name: "slack"
    slack_configs:
      - api_url: {{ vars.vault_alertmanager_slack_api_url | quote }}
        channel: {{ alerting.slack.channel | quote }}
        send_resolved: {{ alerting.slack.send_resolved | default(true) | bool | lower }}
        username: "Observability Framework"
        icon_emoji: ":rotating_light:"
        color: >-
{% raw %}
          {{ if eq .Status "firing" }}{{ if eq .CommonLabels.severity "critical" }}danger{{ else if eq .CommonLabels.severity "warning" }}warning{{ else }}#439FE0{{ end }}{{ else }}good{{ end }}
{% endraw %}
        title: >-
{% raw %}
          {{ if eq .Status "firing" }}{{ if eq .CommonLabels.severity "critical" }}🔴 FIRING CRITICAL{{ else if eq .CommonLabels.severity "warning" }}🟠 FIRING WARNING{{ else }}🔵 FIRING{{ end }}{{ else }}✅ RESOLVED{{ end }} | {{ .CommonLabels.alertname }}
{% endraw %}
        text: |-
{% raw %}
          {{ if match ".*(Primary|SplitBrain|Secondary|Replica|Replication).*" .CommonLabels.alertname }}🔁{{ else if match ".*(CrashLoop|Restart).*" .CommonLabels.alertname }}♻️{{ else if match ".*(Filesystem|Volume|PVC|Disk|Filling|Full).*" .CommonLabels.alertname }}💾{{ else if match ".*(Traefik|Ingress|5xx).*" .CommonLabels.alertname }}🌐{{ else if match ".*(Fluent|Log).*" .CommonLabels.alertname }}📜{{ else if match ".*OpenSearch.*" .CommonLabels.alertname }}🔎{{ else if match ".*(Mongo|Postgres|Database).*" .CommonLabels.alertname }}🗄️{{ else if match ".*(Node|Pod|Deployment|StatefulSet|Kubernetes).*" .CommonLabels.alertname }}☸️{{ else if match ".*(Target|Prometheus|Metrics|Collector).*" .CommonLabels.alertname }}🎯{{ else }}📣{{ end }} *{{ .CommonLabels.alertname }}*
          ----------------------------------------
          *Severity:* `{{ if .CommonLabels.severity }}{{ .CommonLabels.severity }}{{ else }}unknown{{ end }}`
          *Category:* `{{ if .CommonLabels.category }}{{ .CommonLabels.category }}{{ else }}platform{{ end }}`
          *Component:* `{{ if .CommonLabels.component }}{{ .CommonLabels.component }}{{ else }}kube-prometheus-stack{{ end }}`
          *Affected targets:* `{{ len .Alerts }}`
          *Status:* `{{ if eq .Status "resolved" }}recovered{{ else }}active{{ end }}`
          ----------------------------------------
          {{ with index .Alerts 0 }}
          *Summary:* {{ if .Annotations.summary }}{{ .Annotations.summary }}{{ else }}No summary provided{{ end }}
          *Description:* {{ if .Annotations.description }}{{ .Annotations.description }}{{ else }}No description provided{{ end }}
          {{ end }}
          ----------------------------------------
          *Targets:*
          {{ range .Alerts }}
          • {{ if .Labels.node }}node=`{{ .Labels.node }}` {{ end }}{{ if .Labels.namespace }}ns=`{{ .Labels.namespace }}` {{ end }}{{ if .Labels.pod }}pod=`{{ .Labels.pod }}` {{ end }}{{ if .Labels.container }}container=`{{ .Labels.container }}` {{ end }}{{ if .Labels.persistentvolumeclaim }}pvc=`{{ .Labels.persistentvolumeclaim }}` {{ end }}{{ if .Labels.service }}svc=`{{ .Labels.service }}` {{ end }}{{ if .Labels.job }}job=`{{ .Labels.job }}` {{ end }}{{ if .Labels.endpoint }}endpoint=`{{ .Labels.endpoint }}` {{ end }}{{ if .Labels.instance }}instance=`{{ .Labels.instance }}` {{ end }}{{ if .GeneratorURL }}<{{ .GeneratorURL }}|query>{{ end }}
          {{ end }}
{% endraw %}
{% endif %}
{% if webex_enabled %}
  - name: "webex"
    webex_configs:
      - api_url: {{ alerting.webex.api_url | default('https://webexapis.com/v1/messages') | quote }}
        room_id: {{ alerting.webex.room_id | quote }}
        send_resolved: {{ alerting.webex.send_resolved | default(true) | bool | lower }}
        http_config:
          authorization:
            type: Bearer
            credentials: {{ vars.vault_alertmanager_webex_bot_token | quote }}
        message: |-
{% raw %}
          {{ if eq .Status "firing" }}{{ if eq .CommonLabels.severity "critical" }}🔴 FIRING CRITICAL{{ else if eq .CommonLabels.severity "warning" }}🟠 FIRING WARNING{{ else }}🔵 FIRING{{ end }}{{ else }}✅ RESOLVED{{ end }}
          {{ if match ".*(Primary|SplitBrain|Secondary|Replica|Replication).*" .CommonLabels.alertname }}🔁{{ else if match ".*(CrashLoop|Restart).*" .CommonLabels.alertname }}♻️{{ else if match ".*(Filesystem|Volume|PVC|Disk|Filling|Full).*" .CommonLabels.alertname }}💾{{ else if match ".*(Traefik|Ingress|5xx).*" .CommonLabels.alertname }}🌐{{ else if match ".*(Fluent|Log).*" .CommonLabels.alertname }}📜{{ else if match ".*OpenSearch.*" .CommonLabels.alertname }}🔎{{ else if match ".*(Mongo|Postgres|Database).*" .CommonLabels.alertname }}🗄️{{ else if match ".*(Node|Pod|Deployment|StatefulSet|Kubernetes).*" .CommonLabels.alertname }}☸️{{ else if match ".*(Target|Prometheus|Metrics|Collector).*" .CommonLabels.alertname }}🎯{{ else }}📣{{ end }} **{{ .CommonLabels.alertname }}**
          ----------------------------------------
          **Severity:** `{{ if .CommonLabels.severity }}{{ .CommonLabels.severity }}{{ else }}unknown{{ end }}`
          **Category:** `{{ if .CommonLabels.category }}{{ .CommonLabels.category }}{{ else }}platform{{ end }}`
          **Component:** `{{ if .CommonLabels.component }}{{ .CommonLabels.component }}{{ else }}kube-prometheus-stack{{ end }}`
          **Affected targets:** `{{ len .Alerts }}`
          **Status:** `{{ if eq .Status "resolved" }}recovered{{ else }}active{{ end }}`
          ----------------------------------------
          {{ with index .Alerts 0 }}
          **Summary:** {{ if .Annotations.summary }}{{ .Annotations.summary }}{{ else }}No summary provided{{ end }}
          **Description:** {{ if .Annotations.description }}{{ .Annotations.description }}{{ else }}No description provided{{ end }}
          {{ end }}
          ----------------------------------------
          **Targets:**
          {{ range .Alerts }}
          - {{ if .Labels.node }}node=`{{ .Labels.node }}` {{ end }}{{ if .Labels.namespace }}ns=`{{ .Labels.namespace }}` {{ end }}{{ if .Labels.pod }}pod=`{{ .Labels.pod }}` {{ end }}{{ if .Labels.container }}container=`{{ .Labels.container }}` {{ end }}{{ if .Labels.persistentvolumeclaim }}pvc=`{{ .Labels.persistentvolumeclaim }}` {{ end }}{{ if .Labels.service }}svc=`{{ .Labels.service }}` {{ end }}{{ if .Labels.job }}job=`{{ .Labels.job }}` {{ end }}{{ if .Labels.endpoint }}endpoint=`{{ .Labels.endpoint }}` {{ end }}{{ if .Labels.instance }}instance=`{{ .Labels.instance }}` {{ end }}{{ if .GeneratorURL }}[query]({{ .GeneratorURL }}){{ end }}
          {{ end }}
{% endraw %}
{% endif %}
{% if pagerduty_enabled %}
  - name: "pagerduty"
    pagerduty_configs:
      - routing_key: {{ vars.vault_alertmanager_pagerduty_routing_key | quote }}
        send_resolved: {{ alerting.pagerduty.send_resolved | default(true) | bool | lower }}
        client: "Observability Framework"
        client_url: >-
{% raw %}
          {{ .ExternalURL }}
{% endraw %}
        description: >-
{% raw %}
          {{ if eq .Status "firing" }}{{ if eq .CommonLabels.severity "critical" }}🔴 Critical{{ else if eq .CommonLabels.severity "warning" }}🟠 Warning{{ else }}🔵 Alert{{ end }}{{ else }}✅ Resolved{{ end }}: {{ .CommonLabels.alertname }}
{% endraw %}
        severity: >-
{% raw %}
          {{ if eq .CommonLabels.severity "critical" }}critical{{ else if eq .CommonLabels.severity "warning" }}warning{{ else }}info{{ end }}
{% endraw %}
        source: >-
{% raw %}
          {{ if .CommonLabels.namespace }}{{ .CommonLabels.namespace }}{{ else }}observability-framework{{ end }}
{% endraw %}
        component: >-
{% raw %}
          {{ if .CommonLabels.component }}{{ .CommonLabels.component }}{{ else }}kube-prometheus-stack{{ end }}
{% endraw %}
        group: >-
{% raw %}
          {{ if .CommonLabels.category }}{{ .CommonLabels.category }}{{ else }}platform{{ end }}
{% endraw %}
        class: >-
{% raw %}
          {{ .CommonLabels.alertname }}
{% endraw %}
        details:
          alertname: >-
{% raw %}
            {{ .CommonLabels.alertname }}
{% endraw %}
          severity: >-
{% raw %}
            {{ if .CommonLabels.severity }}{{ .CommonLabels.severity }}{{ else }}unknown{{ end }}
{% endraw %}
          category: >-
{% raw %}
            {{ if .CommonLabels.category }}{{ .CommonLabels.category }}{{ else }}platform{{ end }}
{% endraw %}
          component: >-
{% raw %}
            {{ if .CommonLabels.component }}{{ .CommonLabels.component }}{{ else }}kube-prometheus-stack{{ end }}
{% endraw %}
          grouped_alerts: >-
{% raw %}
            {{ len .Alerts }}
{% endraw %}
{% endif %}

inhibit_rules:
  - source_matchers:
      - severity="critical"
    target_matchers:
      - severity="warning"
    equal:
      - alertname
      - namespace
      - pod
      - node
      - persistentvolumeclaim
      - component
