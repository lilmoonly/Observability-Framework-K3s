{% set email_enabled = alerting.email.enabled | default(false) | bool %}
{% set telegram_enabled = alerting.telegram.enabled | default(false) | bool %}
global:
  resolve_timeout: {{ alerting.resolve_timeout | default('5m') }}
{% if email_enabled %}
  smtp_smarthost: {{ alerting.email.smarthost | quote }}
  smtp_from: {{ alerting.email.from | quote }}
  smtp_require_tls: {{ alerting.email.require_tls | default(true) | bool | lower }}
{% if alerting.email.auth_enabled | default(true) | bool %}
  smtp_auth_username: {{ vars.vault_alertmanager_smtp_username | quote }}
  smtp_auth_password: {{ vars.vault_alertmanager_smtp_password | quote }}
{% endif %}
{% endif %}

route:
  receiver: "null"
  group_by:
    - alertname
    - category
    - component
    - severity
    - namespace
  group_wait: {{ alerting.route.group_wait | default('30s') }}
  group_interval: {{ alerting.route.group_interval | default('5m') }}
  repeat_interval: {{ alerting.route.repeat_interval | default('4h') }}
{% if email_enabled or telegram_enabled %}
  routes:
{% if email_enabled %}
    - receiver: "email"
      matchers:
        - severity=~"warning|critical"
      continue: true
{% endif %}
{% if telegram_enabled %}
    - receiver: "telegram"
      matchers:
        - severity=~"warning|critical"
      continue: true
{% endif %}
{% endif %}

receivers:
  - name: "null"
{% if email_enabled %}
  - name: "email"
    email_configs:
      - to: {{ alerting.email.to | quote }}
        from: {{ alerting.email.from | quote }}
        send_resolved: {{ alerting.email.send_resolved | default(true) | bool | lower }}
        headers:
          subject: >-
{% raw %}
            {{ if eq .Status "firing" }}{{ if eq .CommonLabels.severity "critical" }}🔴{{ else if eq .CommonLabels.severity "warning" }}🟠{{ else }}🔵{{ end }} FIRING{{ else }}✅ RESOLVED{{ end }} | {{ if .CommonLabels.component }}{{ .CommonLabels.component }}{{ else }}kube-prometheus-stack{{ end }} | {{ .CommonLabels.alertname }}
{% endraw %}
        html: |-
{% raw %}
          {{ if eq .Status "firing" }}
            {{ if eq .CommonLabels.severity "critical" }}🔴 <b>FIRING CRITICAL</b>{{ else if eq .CommonLabels.severity "warning" }}🟠 <b>FIRING WARNING</b>{{ else }}🔵 <b>FIRING</b>{{ end }}
          {{ else }}
            ✅ <b>RESOLVED</b>
          {{ end }}
          <br/>
          {{ if match ".*(Primary|SplitBrain|Secondary|Replica|Replication).*" .CommonLabels.alertname }}🔁{{ else if match ".*(CrashLoop|Restart).*" .CommonLabels.alertname }}♻️{{ else if match ".*(Filesystem|Volume|PVC|Disk|Filling|Full).*" .CommonLabels.alertname }}💾{{ else if match ".*(Traefik|Ingress|5xx).*" .CommonLabels.alertname }}🌐{{ else if match ".*(Fluent|Log).*" .CommonLabels.alertname }}📜{{ else if match ".*OpenSearch.*" .CommonLabels.alertname }}🔎{{ else if match ".*(Mongo|Postgres|Database).*" .CommonLabels.alertname }}🗄️{{ else if match ".*(Node|Pod|Deployment|StatefulSet|Kubernetes).*" .CommonLabels.alertname }}☸️{{ else if match ".*(Target|Prometheus|Metrics|Collector).*" .CommonLabels.alertname }}🎯{{ else }}📣{{ end }}
          <b>{{ .CommonLabels.alertname }}</b><br/>
          <br/>
          <b>Severity:</b> <code>{{ if .CommonLabels.severity }}{{ .CommonLabels.severity }}{{ else }}unknown{{ end }}</code><br/>
          <b>Category:</b> <code>{{ if .CommonLabels.category }}{{ .CommonLabels.category }}{{ else }}platform{{ end }}</code><br/>
          <b>Component:</b> <code>{{ if .CommonLabels.component }}{{ .CommonLabels.component }}{{ else }}kube-prometheus-stack{{ end }}</code><br/>
          <b>Grouped alerts:</b> <code>{{ len .Alerts }}</code><br/>
          <br/>
          {{ range .Alerts }}
          <hr/>
          <b>Summary:</b> {{ if .Annotations.summary }}{{ .Annotations.summary }}{{ else }}No summary provided{{ end }}<br/>
          <b>Description:</b> {{ if .Annotations.description }}{{ .Annotations.description }}{{ else }}No description provided{{ end }}<br/>
          {{ if .Labels.namespace }}<b>Namespace:</b> <code>{{ .Labels.namespace }}</code><br/>{{ end }}
          {{ if .Labels.pod }}<b>Pod:</b> <code>{{ .Labels.pod }}</code><br/>{{ end }}
          {{ if .Labels.container }}<b>Container:</b> <code>{{ .Labels.container }}</code><br/>{{ end }}
          {{ if .Labels.node }}<b>Node:</b> <code>{{ .Labels.node }}</code><br/>{{ end }}
          {{ if .Labels.persistentvolumeclaim }}<b>PVC:</b> <code>{{ .Labels.persistentvolumeclaim }}</code><br/>{{ end }}
          {{ if .Labels.service }}<b>Service:</b> <code>{{ .Labels.service }}</code><br/>{{ end }}
          {{ if .Labels.job }}<b>Job:</b> <code>{{ .Labels.job }}</code><br/>{{ end }}
          {{ if .Labels.instance }}<b>Instance:</b> <code>{{ .Labels.instance }}</code><br/>{{ end }}
          {{ if .GeneratorURL }}<b>Prometheus:</b> <a href="{{ .GeneratorURL }}">open query</a><br/>{{ end }}
          <br/>
          {{ end }}
{% endraw %}
{% endif %}
{% if telegram_enabled %}
  - name: "telegram"
    telegram_configs:
      - bot_token: {{ vars.vault_alertmanager_telegram_bot_token | quote }}
        chat_id: {{ vars.vault_alertmanager_telegram_chat_id | int }}
        parse_mode: "HTML"
        send_resolved: {{ alerting.telegram.send_resolved | default(true) | bool | lower }}
        message: |-
{% raw %}
          {{ if eq .Status "firing" }}{{ if eq .CommonLabels.severity "critical" }}🔴 <b>FIRING CRITICAL</b>{{ else if eq .CommonLabels.severity "warning" }}🟠 <b>FIRING WARNING</b>{{ else }}🔵 <b>FIRING</b>{{ end }}{{ else }}✅ <b>RESOLVED</b>{{ end }}
          {{ if match ".*(Primary|SplitBrain|Secondary|Replica|Replication).*" .CommonLabels.alertname }}🔁{{ else if match ".*(CrashLoop|Restart).*" .CommonLabels.alertname }}♻️{{ else if match ".*(Filesystem|Volume|PVC|Disk|Filling|Full).*" .CommonLabels.alertname }}💾{{ else if match ".*(Traefik|Ingress|5xx).*" .CommonLabels.alertname }}🌐{{ else if match ".*(Fluent|Log).*" .CommonLabels.alertname }}📜{{ else if match ".*OpenSearch.*" .CommonLabels.alertname }}🔎{{ else if match ".*(Mongo|Postgres|Database).*" .CommonLabels.alertname }}🗄️{{ else if match ".*(Node|Pod|Deployment|StatefulSet|Kubernetes).*" .CommonLabels.alertname }}☸️{{ else if match ".*(Target|Prometheus|Metrics|Collector).*" .CommonLabels.alertname }}🎯{{ else }}📣{{ end }} <b>{{ .CommonLabels.alertname }}</b>

          <b>Severity:</b> <code>{{ if .CommonLabels.severity }}{{ .CommonLabels.severity }}{{ else }}unknown{{ end }}</code>
          <b>Category:</b> <code>{{ if .CommonLabels.category }}{{ .CommonLabels.category }}{{ else }}platform{{ end }}</code>
          <b>Component:</b> <code>{{ if .CommonLabels.component }}{{ .CommonLabels.component }}{{ else }}kube-prometheus-stack{{ end }}</code>
          <b>Grouped alerts:</b> <code>{{ len .Alerts }}</code>

          {{ range .Alerts }}
          ----------
          <b>Summary:</b> {{ if .Annotations.summary }}{{ .Annotations.summary }}{{ else }}No summary provided{{ end }}
          <b>Description:</b> {{ if .Annotations.description }}{{ .Annotations.description }}{{ else }}No description provided{{ end }}
          {{ if .Labels.namespace }}<b>Namespace:</b> <code>{{ .Labels.namespace }}</code>{{ end }}
          {{ if .Labels.pod }}<b>Pod:</b> <code>{{ .Labels.pod }}</code>{{ end }}
          {{ if .Labels.container }}<b>Container:</b> <code>{{ .Labels.container }}</code>{{ end }}
          {{ if .Labels.node }}<b>Node:</b> <code>{{ .Labels.node }}</code>{{ end }}
          {{ if .Labels.persistentvolumeclaim }}<b>PVC:</b> <code>{{ .Labels.persistentvolumeclaim }}</code>{{ end }}
          {{ if .Labels.service }}<b>Service:</b> <code>{{ .Labels.service }}</code>{{ end }}
          {{ if .Labels.job }}<b>Job:</b> <code>{{ .Labels.job }}</code>{{ end }}
          {{ if .Labels.instance }}<b>Instance:</b> <code>{{ .Labels.instance }}</code>{{ end }}
          {{ if .GeneratorURL }}<a href="{{ .GeneratorURL }}">Open in Prometheus</a>{{ end }}

          {{ end }}
{% endraw %}
{% endif %}

inhibit_rules:
  - source_matchers:
      - severity="critical"
    target_matchers:
      - severity="warning"
    equal:
      - alertname
      - namespace
      - pod
      - node
      - persistentvolumeclaim
      - component
