{
  "title": "Error Frequency from Logs",
  "uid": "error-frequency",
  "tags": ["logs", "errors", "opensearch"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Error Rate Over Time",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
      "targets": [
        {
          "refId": "A",
          "alias": "Errors",
          "query": "log:(*error* OR *ERROR* OR *Error* OR *fail* OR *FATAL*) OR stream:\"stderr\"",
          "queryType": "lucene",
          "timeField": "@timestamp",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            {
              "id": "2",
              "type": "date_histogram",
              "field": "@timestamp",
              "settings": { "interval": "auto", "min_doc_count": "0" }
            }
          ]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      }
    },
    {
      "id": 5,
      "title": "Errors by Kubernetes Namespace",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
      "targets": [
        {
          "refId": "A",
          "query": "log:(*error* OR *ERROR* OR *Error*) OR stream:\"stderr\"",
          "queryType": "lucene",
          "timeField": "@timestamp",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            {
              "id": "2",
              "type": "terms",
              "field": "kubernetes.namespace_name.keyword",
              "settings": { "size": "10", "order": "desc", "orderBy": "_count" }
            }
          ]
        }
      ]
    },
    {
      "id": 6,
      "title": "Top Error Messages",
      "type": "table",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 17 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
      "targets": [
        {
          "refId": "A",
          "query": "log:(*error* OR *ERROR* OR *Error*) OR stream:\"stderr\"",
          "queryType": "lucene",
          "timeField": "@timestamp",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            {
              "id": "2",
              "type": "terms",
              "field": "log.keyword",
              "settings": { "size": "20", "order": "desc", "orderBy": "_count" }
            }
          ]
        }
      ]
    }
  ]
}