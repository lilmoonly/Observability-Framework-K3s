{
  "title": "Error Distribution by Category",
  "uid": "error-distribution",
  "tags": ["logs", "errors", "distribution", "opensearch"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 4,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Distribution by Container",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
      "targets": [
        {
          "refId": "A",
          "query": "stream.keyword:stderr",
          "queryType": "lucene",
          "timeField": "@timestamp",
          "isLogsQuery": false,
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            {
              "id": "2",
              "type": "terms",
              "field": "kubernetes.container_name.keyword",
              "settings": { "size": "10", "order": "desc", "orderBy": "_count" }
            }
          ]
        }
      ],
      "options": {
        "pieType": "donut",
        "displayLabels": ["name", "percent"],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": ["value", "percent"]
        }
      }
    },
    {
      "id": 2,
      "title": "Distribution by Node",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
      "targets": [
        {
          "refId": "A",
          "query": "stream.keyword:stderr",
          "queryType": "lucene",
          "timeField": "@timestamp",
          "isLogsQuery": false,
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            {
              "id": "2",
              "type": "terms",
              "field": "kubernetes.host.keyword",
              "settings": { "size": "10", "order": "desc", "orderBy": "_count" }
            }
          ]
        }
      ],
      "options": {
        "pieType": "donut",
        "displayLabels": ["name", "percent"],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": ["value", "percent"]
        }
      }
    },
    {
      "id": 3,
      "title": "stderr Volume Heatmap by Hour",
      "type": "heatmap",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 10 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
      "targets": [
        {
          "refId": "A",
          "query": "stream.keyword:stderr",
          "queryType": "lucene",
          "timeField": "@timestamp",
          "isLogsQuery": false,
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            {
              "id": "2",
              "type": "date_histogram",
              "field": "@timestamp",
              "settings": { "interval": "1h", "min_doc_count": "0" }
            }
          ]
        }
      ],
      "options": {
        "calculate": false,
        "color": { "scheme": "Oranges", "steps": 32 },
        "cellGap": 1
      }
    },
    {
      "id": 4,
      "title": "stderr vs stdout Trend",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
      "targets": [
        {
          "refId": "A",
          "alias": "stderr",
          "query": "stream.keyword:stderr",
          "queryType": "lucene",
          "timeField": "@timestamp",
          "isLogsQuery": false,
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            {
              "id": "2",
              "type": "date_histogram",
              "field": "@timestamp",
              "settings": { "interval": "30m", "min_doc_count": "0" }
            }
          ]
        },
        {
          "refId": "B",
          "alias": "stdout",
          "query": "stream.keyword:stdout",
          "queryType": "lucene",
          "timeField": "@timestamp",
          "isLogsQuery": false,
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            {
              "id": "2",
              "type": "date_histogram",
              "field": "@timestamp",
              "settings": { "interval": "30m", "min_doc_count": "0" }
            }
          ]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "stderr" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "stdout" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }
            ]
          }
        ]
      }
    },
    {
      "id": 5,
      "title": "stderr by Namespace",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 29 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
      "targets": [
        {
          "refId": "A",
          "query": "stream.keyword:stderr",
          "queryType": "lucene",
          "timeField": "@timestamp",
          "isLogsQuery": false,
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            {
              "id": "2",
              "type": "terms",
              "field": "kubernetes.namespace_name.keyword",
              "settings": { "size": "10", "order": "desc", "orderBy": "_count" }
            }
          ]
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "stderr by Container",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 29 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
      "targets": [
        {
          "refId": "A",
          "query": "stream.keyword:stderr",
          "queryType": "lucene",
          "timeField": "@timestamp",
          "isLogsQuery": false,
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            {
              "id": "2",
              "type": "terms",
              "field": "kubernetes.container_name.keyword",
              "settings": { "size": "10", "order": "desc", "orderBy": "_count" }
            }
          ]
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      }
    }
  ]
}