{
  "title": "Error Distribution by Category",
  "uid": "error-distribution",
  "tags": ["logs", "errors", "distribution", "opensearch"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 2,
      "title": "Distribution by Service",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
      "targets": [
        {
          "refId": "A",
          "query": "log:(*error* OR *ERROR* OR *Error*) OR stream:\"stderr\"",
          "queryType": "lucene",
          "timeField": "@timestamp",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            {
              "id": "2",
              "type": "terms",
              "field": "kubernetes.container_name.keyword",
              "settings": { "size": "10", "order": "desc", "orderBy": "_count" }
            }
          ]
        }
      ],
      "options": {
        "pieType": "donut",
        "displayLabels": ["name", "percent"],
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }
      }
    },
    {
      "id": 3,
      "title": "Distribution by Node",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
      "targets": [
        {
          "refId": "A",
          "query": "log:(*error* OR *ERROR* OR *Error*) OR stream:\"stderr\"",
          "queryType": "lucene",
          "timeField": "@timestamp",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            {
              "id": "2",
              "type": "terms",
              "field": "kubernetes.host.keyword",
              "settings": { "size": "10", "order": "desc", "orderBy": "_count" }
            }
          ]
        }
      ],
      "options": {
        "pieType": "donut",
        "displayLabels": ["name", "percent"],
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }
      }
    },
    {
      "id": 4,
      "title": "Error Heatmap — Hour by Day",
      "type": "heatmap",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 10 },
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
      "targets": [
        {
          "refId": "A",
          "query": "log:(*error* OR *ERROR* OR *Error*) OR stream:\"stderr\"",
          "queryType": "lucene",
          "timeField": "@timestamp",
          "metrics": [{ "id": "1", "type": "count" }],
          "bucketAggs": [
            {
              "id": "2",
              "type": "date_histogram",
              "field": "@timestamp",
              "settings": { "interval": "1h", "min_doc_count": "0" }
            }
          ]
        }
      ],
      "options": {
        "color": { "scheme": "Oranges" }
      }
    }
  ]
}