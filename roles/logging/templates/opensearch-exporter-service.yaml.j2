apiVersion: v1
kind: Service
metadata:
  name: opensearch-exporter
  namespace: opensearch
  labels:
    app.kubernetes.io/name: opensearch-exporter
    app.kubernetes.io/component: metrics
spec:
  type: ClusterIP
  selector:
    app.kubernetes.io/name: opensearch-exporter
  ports:
    - name: metrics
      port: 9114
      targetPort: metrics
