apiVersion: monitoring.coreos.com/v1
kind: ServiceMonitor
metadata:
  name: fluent-bit-metrics
  namespace: opensearch
  labels:
    release: prometheus
spec:
  namespaceSelector:
    matchNames:
      - opensearch
  selector:
    matchLabels:
      app.kubernetes.io/name: fluent-bit-metrics
  endpoints:
    - port: metrics
      path: /api/v1/metrics/prometheus
      interval: 30s
