{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "panel",
      "id": "gauge",
      "name": "Gauge",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "Prometheus",
      "description": "Ready means the model has enough aligned Prometheus samples to begin anomaly scoring.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "yellow",
                  "text": "Warming Up"
                },
                "1": {
                  "color": "green",
                  "text": "Ready"
                }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "yellow",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "max(ai_anomaly_ready)",
          "instant": true,
          "legendFormat": "Detector state",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Detector State",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "Percent of required aligned Prometheus samples already collected.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 0,
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.4
              },
              {
                "color": "yellow",
                "value": 0.75
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "id": 2,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "clamp_max(max(ai_anomaly_available_samples) / clamp_min(max(ai_anomaly_required_samples), 1), 1)",
          "instant": true,
          "legendFormat": "Training progress",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Training Progress",
      "type": "gauge"
    },
    {
      "datasource": "Prometheus",
      "description": "When this reaches 0, the detector has enough history to score anomalies.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 0,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "clamp_min(max(ai_anomaly_required_samples) - max(ai_anomaly_available_samples), 0)",
          "instant": true,
          "legendFormat": "Samples remaining",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Samples Remaining",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "Latest normalized score from the model. Compare it with the threshold line in the timeline below.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 2,
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.75
              },
              {
                "color": "red",
                "value": 0.9
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "max(ai_anomaly_score_normalized)",
          "instant": true,
          "legendFormat": "Current score",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Current Score",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "How many anomaly events the AI engine has written to OpenSearch in the last 24 hours.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 16,
        "y": 0
      },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(increase(ai_anomaly_events_total[24h]))",
          "instant": true,
          "legendFormat": "Published anomaly events in last 24h",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Published Anomaly Events (24h)",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "Shows when the detector last completed a successful evaluation.",
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "options": {
                "0": {
                  "color": "yellow",
                  "text": "No successful run yet"
                }
              },
              "type": "value"
            }
          ],
          "unit": "dateTimeFromNow"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "id": 6,
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "max(ai_anomaly_last_success_timestamp_seconds) * 1000",
          "instant": true,
          "legendFormat": "Last successful run",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Last Successful Run",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "The detector is actionable when the score crosses the threshold and the detected line jumps to 1.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "never",
            "spanNulls": false
          },
          "decimals": 2,
          "max": 1,
          "min": 0
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Anomaly threshold"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "orange",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Detected (0/1)"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 14,
        "x": 0,
        "y": 5
      },
      "id": 7,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "max(ai_anomaly_score_normalized)",
          "legendFormat": "Normalized score",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "max(ai_anomaly_threshold)",
          "legendFormat": "Anomaly threshold",
          "range": true,
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "max(ai_anomaly_detected)",
          "legendFormat": "Detected (0/1)",
          "range": true,
          "refId": "C"
        }
      ],
      "title": "Score vs Threshold",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Current feature values used by the detector. This table is populated even during warm-up.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 10,
        "x": 14,
        "y": 5
      },
      "id": 8,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "max by (feature) (ai_feature_value)",
          "format": "table",
          "instant": true,
          "legendFormat": "{{feature}}",
          "range": false,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "feature": 0,
              "Value": 1
            },
            "renameByName": {
              "feature": "Feature",
              "Value": "Current value"
            }
          }
        }
      ],
      "title": "Current Feature Snapshot",
      "type": "table"
    },
    {
      "datasource": "Prometheus",
      "description": "Core cluster-level feature trends feeding the AI model.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "never",
            "spanNulls": false
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 13
      },
      "id": 9,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "max(ai_feature_value{feature=\"cluster_cpu_usage_pct\"})",
          "legendFormat": "CPU usage %",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "max(ai_feature_value{feature=\"cluster_memory_usage_pct\"})",
          "legendFormat": "Memory usage %",
          "range": true,
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "max(ai_feature_value{feature=\"cluster_disk_usage_pct\"})",
          "legendFormat": "Disk usage %",
          "range": true,
          "refId": "C"
        }
      ],
      "title": "Resource Trend",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Workload and platform health inputs that often explain why the detector raised a score.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 13
      },
      "id": 10,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "max(ai_feature_value{feature=\"running_pods\"})",
          "legendFormat": "Running pods",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "max(ai_feature_value{feature=\"pending_pods\"})",
          "legendFormat": "Pending pods",
          "range": true,
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "max(ai_feature_value{feature=\"failed_pods\"})",
          "legendFormat": "Failed pods",
          "range": true,
          "refId": "C"
        },
        {
          "editorMode": "code",
          "expr": "max(ai_feature_value{feature=\"pod_restart_delta_15m\"})",
          "legendFormat": "Container restarts / 15m",
          "range": true,
          "refId": "D"
        },
        {
          "editorMode": "code",
          "expr": "max(ai_feature_value{feature=\"max_namespace_restarts_15m\"})",
          "legendFormat": "Max namespace restarts / 15m",
          "range": true,
          "refId": "E"
        },
        {
          "editorMode": "code",
          "expr": "max(ai_feature_value{feature=\"node_not_ready_count\"})",
          "legendFormat": "Not ready nodes",
          "range": true,
          "refId": "F"
        }
      ],
      "title": "Workload Health Trend",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "Higher z-scores indicate the strongest residual contributors after subtracting the rolling baseline. This table appears after the first successful model fit.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "decimals": 2
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 21
      },
      "id": 11,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "max by (feature) (ai_feature_zscore)",
          "format": "table",
          "instant": true,
          "legendFormat": "{{feature}}",
          "range": false,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "feature": 0,
              "Value": 1
            },
            "renameByName": {
              "feature": "Feature",
              "Value": "Z-score"
            }
          }
        }
      ],
      "title": "Contributor Ranking",
      "type": "table"
    },
    {
      "datasource": "Prometheus",
      "description": "Rolling one-hour activity for the detector. Use this to see whether it is actively evaluating, failing, publishing anomaly events, or suppressing duplicates.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "never",
            "spanNulls": false
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 21
      },
      "id": 12,
      "options": {
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum(increase(ai_anomaly_runs_total[1h]))",
          "legendFormat": "Runs last hour",
          "range": true,
          "refId": "A"
        },
        {
          "editorMode": "code",
          "expr": "sum(increase(ai_anomaly_run_failures_total[1h]))",
          "legendFormat": "Failures last hour",
          "range": true,
          "refId": "B"
        },
        {
          "editorMode": "code",
          "expr": "sum(increase(ai_anomaly_events_total[1h]))",
          "legendFormat": "Published anomalies last hour",
          "range": true,
          "refId": "C"
        },
        {
          "editorMode": "code",
          "expr": "sum(increase(ai_anomaly_suppressed_total[1h]))",
          "legendFormat": "Suppressed duplicates last hour",
          "range": true,
          "refId": "D"
        }
      ],
      "title": "Detector Activity",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": [
    "ai",
    "anomaly-detection",
    "observability-framework"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
