        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": "Prometheus",
      "description": "Ready means the detector has enough aligned Prometheus history to score anomalies.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "yellow",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "Warming Up",
                  "color": "yellow"
                },
                "1": {
                  "text": "Ready",
                  "color": "green"
                }
              }
            }
          ]
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "max(ai_anomaly_ready)",
          "instant": true,
          "legendFormat": "Detector state",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Detector State",
      "type": "stat"
    },
    {
      "datasource": "Prometheus",
      "description": "Progress is based on Prometheus history, not pod uptime.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 0,
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.4
              },
              {
                "color": "yellow",
                "value": 0.75
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "id": 2,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "clamp_max(max(ai_anomaly_available_samples) / clamp_min(max(ai_anomaly_required_samples), 1), 1)",
          "instant": true,
          "legendFormat": "Training progress",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Training Progress",
      "type": "gauge"
    },
    {
      "datasource": "Prometheus",
      "description": "How many aligned time steps are currently available from Prometheus history.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "yellow",
                "value": null
              },
              {
                "color": "green",
                "value": 37
              }
            ]
