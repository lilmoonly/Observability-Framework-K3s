    {
      "datasource": "Prometheus",
      "description": "Higher residual z-scores mean the feature deviated further from its rolling baseline and contributed more strongly to the latest anomaly decision. The table is sorted from strongest contributor to weakest.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          },
          "decimals": 2
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 12,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "showHeader": true
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sort_desc(max by (feature) (ai_feature_zscore))",
          "format": "table",
          "instant": true,
          "legendFormat": "{{feature}}",
          "range": false,
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "feature": 0,
              "Value": 1
            },
            "renameByName": {
              "feature": "Feature",
              "Value": "Residual Z-score"
            }
          }
        }
      ],
      "title": "Why It Triggered",
      "type": "table"
    },
