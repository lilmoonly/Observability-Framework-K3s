apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ ai_engine.app_name }}
  namespace: {{ ai_engine.namespace }}
  labels:
    app.kubernetes.io/name: {{ ai_engine.app_name }}
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: {{ ai_engine.app_name }}
  template:
    metadata:
      annotations:
        checksum/ai-engine-app: "{{ (lookup('file', role_path + '/files/app/main.py') ~ lookup('file', role_path + '/files/app/requirements.txt')) | hash('sha1') }}"
      labels:
        app.kubernetes.io/name: {{ ai_engine.app_name }}
    spec:
      nodeSelector:
        workload: {{ ai_engine.node_selector_label }}
      tolerations:
        - key: workload
          operator: Equal
          value: {{ ai_engine.node_selector_label }}
          effect: NoSchedule
      containers:
        - name: {{ ai_engine.app_name }}
          image: {{ ai_engine.image }}
          imagePullPolicy: IfNotPresent
          command:
            - /bin/sh
            - -c
          args:
            - >-
              pip install --no-cache-dir -r /app/requirements.txt &&
              python /app/main.py
          env:
            - name: APP_PORT
              value: "{{ ai_engine.port }}"
            - name: CHECK_INTERVAL_SECONDS
              value: "{{ ai_engine.check_interval_seconds }}"
            - name: TRAINING_WINDOW_HOURS
              value: "{{ ai_engine.lookback_hours }}"
            - name: STEP_SECONDS
              value: "{{ ai_engine.step_seconds }}"
            - name: ANOMALY_THRESHOLD
              value: "{{ ai_engine.anomaly_threshold }}"
            - name: ROLLING_BASELINE_SAMPLES
              value: "{{ ai_engine.rolling_baseline_samples }}"
            - name: CONTAMINATION
              value: "{{ ai_engine.contamination }}"
            - name: MIN_TRAINING_SAMPLES
              value: "{{ ai_engine.min_training_samples }}"
            - name: SUPPRESSION_WINDOW_SECONDS
              value: "{{ ai_engine.suppression_window_seconds }}"
            - name: RULE_RESTART_DELTA_THRESHOLD
              value: "{{ ai_engine.rule_thresholds.restart_delta_15m }}"
            - name: RULE_PENDING_PODS_THRESHOLD
              value: "{{ ai_engine.rule_thresholds.pending_pods }}"
            - name: RULE_FAILED_PODS_THRESHOLD
              value: "{{ ai_engine.rule_thresholds.failed_pods }}"
            - name: RULE_NODE_NOT_READY_THRESHOLD
              value: "{{ ai_engine.rule_thresholds.node_not_ready }}"
            - name: RULE_NODE_PRESSURE_THRESHOLD
              value: "{{ ai_engine.rule_thresholds.node_pressure }}"
            - name: RULE_APISERVER_5XX_RATE_THRESHOLD
              value: "{{ ai_engine.rule_thresholds.apiserver_5xx_rate }}"
            - name: RULE_INGRESS_5XX_RATE_THRESHOLD
              value: "{{ ai_engine.rule_thresholds.ingress_5xx_rate }}"
            - name: SEVERITY_CRITICAL_SCORE
              value: "{{ ai_engine.severity_thresholds.critical_score }}"
            - name: PROMETHEUS_URL
              value: "{{ ai_engine.prometheus_url }}"
            - name: OPENSEARCH_URL
              value: "{{ ai_engine.opensearch_url }}"
            - name: OPENSEARCH_USERNAME
              valueFrom:
                secretKeyRef:
                  name: ai-engine-secret
                  key: OPENSEARCH_USERNAME
            - name: OPENSEARCH_PASSWORD
              valueFrom:
                secretKeyRef:
                  name: ai-engine-secret
                  key: OPENSEARCH_PASSWORD
          ports:
            - name: metrics
              containerPort: {{ ai_engine.port }}
          volumeMounts:
            - name: app
              mountPath: /app
          startupProbe:
            httpGet:
              path: /metrics
              port: metrics
            initialDelaySeconds: 15
            periodSeconds: 10
            failureThreshold: 60
            timeoutSeconds: 10
          readinessProbe:
            httpGet:
              path: /metrics
              port: metrics
            initialDelaySeconds: 5
            periodSeconds: 15
            timeoutSeconds: 5
          livenessProbe:
            httpGet:
              path: /metrics
              port: metrics
            initialDelaySeconds: 10
            periodSeconds: 20
            timeoutSeconds: 5
          resources:
            requests:
              cpu: {{ ai_engine.resources.requests.cpu }}
              memory: {{ ai_engine.resources.requests.memory }}
            limits:
              cpu: {{ ai_engine.resources.limits.cpu }}
              memory: {{ ai_engine.resources.limits.memory }}
      volumes:
        - name: app
          configMap:
            name: ai-engine-app
