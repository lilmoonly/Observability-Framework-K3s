---
# Copy this file to:
#   inventory/group_vars/all/secrets.yml
#
# Then encrypt it before use:
#   ansible-vault encrypt inventory/group_vars/all/secrets.yml
#
# Example deploy command:
#   ansible-playbook -i inventory/inventory.ini site.yml --ask-vault-pass

vault_k3s_token: "replace-with-k3s-cluster-join-token"
vault_opensearch_admin_password: "replace-with-opensearch-admin-password"
vault_grafana_admin_password: "replace-with-grafana-admin-password"
vault_database_superuser_password: "replace-with-database-admin-password"
vault_database_app_password: "replace-with-application-db-password"
vault_forgejo_admin_password: "replace-with-forgejo-admin-password"
vault_wekan_admin_password: "replace-with-wekan-admin-password"
vault_alertmanager_smtp_username: "replace-with-smtp-username"
vault_alertmanager_smtp_password: "replace-with-smtp-password-or-app-password"
vault_alertmanager_telegram_bot_token: "replace-with-telegram-bot-token"
vault_alertmanager_telegram_chat_id: "replace-with-telegram-chat-id"
vault_alertmanager_slack_api_url: "replace-with-slack-incoming-webhook-url"
vault_alertmanager_webex_bot_token: "replace-with-webex-bot-token"
vault_alertmanager_pagerduty_routing_key: "replace-with-pagerduty-events-api-v2-routing-key"
